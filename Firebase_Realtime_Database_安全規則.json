{
  "rules": {
    // 預設全部拒絕（未列出的路徑都不能讀寫）
    ".read": false,
    ".write": false,

    // 員工資料：每位員工只能讀自己那筆，只有 admin 能寫
    "staff": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('staff').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['role','email'])"
      }
    },

    // 菜單：任何人可讀（顧客點餐頁未登入也要能載入菜單），登入者可寫（POS 同步用）
    // ★ 修正：原本 .read 寫成 auth != null 會讓顧客點餐頁完全打不開
    "menu": {
      "$projectId": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    // POS 店家備份：依 storeId 分店存放，登入者可讀寫
    "posBackup": {
      "$storeId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    // 客戶資料：登入者可讀寫
    "customers": {
      "$customerKey": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    // 客戶訂單歷史：依建立時間與查詢鍵建立索引，登入者可讀寫
    "customerOrders": {
      ".indexOn": ["createdAt", "customerLookupKey"],
      "$orderId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    // 線上訂單：依分店代碼分群（如 store001），索引常用查詢欄位
    // ★ $storeCode 層加 .read：讓 POS 能監聽整個店的訂單清單（onValue 對父層生效）
    "onlineOrders": {
      "$storeCode": {
        ".read": "auth != null",
        ".indexOn": ["createdAt", "status", "customerPhone"],
        "$orderId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },

    // 多店即時看板：依 storeId 分店，含 heartbeat / today / session / businessHours / _debug 等子節點，登入者可讀寫
    "dashboards": {
      "$storeId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
