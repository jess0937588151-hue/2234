{
  "rules": {
    ".read": false,
    ".write": false,
    "staff": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('staff').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('staff').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['role','email']) && newData.child('role').isString() && (newData.child('role').val() === 'admin' || newData.child('role').val() === 'staff') && newData.child('email').isString()"
      }
    },
    "menu": {
      "$projectId": {
        ".read": true,
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('canPublishMenu').val() === true)",
        ".validate": "newData.hasChildren(['categories','products','modules','updatedAt'])"
      }
    },
    "onlineOrders": {
      "$storeCode": {
        ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeCode).val() === true)",
        ".indexOn": [
          "createdAt",
          "status",
          "customerUid",
          "customerLookupKey"
        ],
        "$orderId": {
          ".read": "auth != null && (data.child('customerUid').val() === auth.uid || root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeCode).val() === true)",
          ".write": "auth != null && ((!data.exists() && newData.child('customerUid').val() === auth.uid && newData.child('storeCode').val() === $storeCode && newData.child('status').val() === 'pending_confirm') || (data.exists() && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeCode).val() === true) && newData.child('storeCode').val() === $storeCode))",
          ".validate": "newData.hasChildren(['storeCode','customerUid','customerName','customerPhone','items','status','createdAt','updatedAt']) && newData.child('storeCode').val() === $storeCode && newData.child('customerUid').isString() && newData.child('customerName').isString() && newData.child('customerPhone').isString() && newData.child('items').hasChildren() && (newData.child('status').val() === 'pending_confirm' || newData.child('status').val() === 'confirmed' || newData.child('status').val() === 'rejected' || newData.child('status').val() === 'completed' || newData.child('status').val() === 'cancelled')"
        }
      }
    },
    "customerOrderLookup": {
      "$storeCode": {
        "$lookupKey": {
          ".read": "auth != null",
          "$orderId": {
            ".write": "auth != null && ((!data.exists() && newData.child('customerUid').val() === auth.uid) || (data.exists() && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeCode).val() === true)))",
            ".validate": "newData.hasChildren(['id','orderNo','createdAt','updatedAt','status','total','customerUid','items']) && newData.child('customerUid').isString()"
          }
        }
      }
    },
    "publicOnlineStores": {
      "$storeCode": {
        ".read": true,
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeCode).val() === true)",
        ".validate": "newData.hasChildren(['storeId','promotions','updatedAt']) && newData.child('storeId').val() === $storeCode",
        "promotions": {
          ".validate": "newData.hasChildren(['enabled','banners','coupons'])"
        },
        "productAvailability": {
          "$productId": {
            ".validate": "newData.hasChildren(['enabled','soldOut','updatedAt']) && newData.child('enabled').isBoolean() && newData.child('soldOut').isBoolean() && newData.child('updatedAt').isString()"
          }
        }
      }
    },
    "dashboards": {
      ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('role').val() === 'staff')",
      "$storeId": {
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeId).val() === true)"
      }
    },
    "posBackup": {
      "$storeId": {
        ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeId).val() === true)",
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeId).val() === true)"
      }
    },
    "sessionHistory": {
      "$storeId": {
        ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeId).val() === true)",
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('stores').child($storeId).val() === true)"
      }
    },
    "customers": {
      "$customerKey": {
        ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('role').val() === 'staff')",
        ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('role').val() === 'staff')"
      }
    },
    "customerOrders": {
      "$customerKey": {
        "$orderId": {
          ".read": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('role').val() === 'staff')",
          ".write": "auth != null && (root.child('staff').child(auth.uid).child('role').val() === 'admin' || root.child('staff').child(auth.uid).child('role').val() === 'staff')"
        }
      }
    }
  }
}
